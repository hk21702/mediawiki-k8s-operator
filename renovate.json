{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "composer": {
    "enabled": false // Doesn't work well with non-semver and git-based dependencies. Certain extension updates may be incompatible.
  },
  "customDatasources": {
    "charmhub": {
      "defaultRegistryUrlTemplate": "https://api.charmhub.io/v2/charms/info/{{packageName}}?fields=channel-map",
      "format": "json",
      "transformTemplates": [
        "{\"releases\": [{\"version\": $string($$.(`channel-map`[channel.risk = 'edge' and channel.track = '1.45' and channel.base.architecture = 'amd64' and channel.base.channel = '24.04'].revision.revision))}]}"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "description": "Update base image references",
      "managerFilePatterns": [
        "/(^|/)rockcraft.yaml$/"
      ],
      "matchStrings": [
        "# renovate: build-base:\\s+(?<depName>[^:]*):(?<currentValue>[^\\s@]*)(@(?<currentDigest>sha256:[0-9a-f]*))?",
        "# renovate: base:\\s+(?<depName>[^:]*):(?<currentValue>[^\\s@]*)(@(?<currentDigest>sha256:[0-9a-f]*))?"
      ],
      "matchStringsStrategy": "any",
      "versioningTemplate": "ubuntu"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "git-tags",
      "depNameTemplate": "https://gerrit.wikimedia.org/r/mediawiki/core.git",
      "description": "Update MediaWiki MW_VERSION from upstream tags",
      "managerFilePatterns": [
        "/(^|/)mediawiki_rock/rockcraft.yaml$/"
      ],
      "matchStrings": [
        "- MW_VERSION:\\s*(?<currentValue>[^\\s]+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "Lusitaniae/apache_exporter",
      "description": "Update Apache Exporter source",
      "managerFilePatterns": [
        "/(^|/)rockcraft.yaml$/"
      ],
      "matchStrings": [
        "source:.*Lusitaniae/apache_exporter\\.git.*\\n.*source-tag: (?<currentValue>.+)"
      ],
      "matchStringsStrategy": "any",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "description": "Update git-sync upstream-source in charmcraft.yaml",
      "managerFilePatterns": [
        "/(^|/)charmcraft.yaml$/"
      ],
      "matchStrings": [
        "git-sync-image:[\\s\\S]*?upstream-source:\\s*(?<depName>[^:]+):(?<currentValue>[^\\s@]*)(@(?<currentDigest>sha256:[0-9a-f]*))?"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "custom.charmhub",
      "description": "Update charm revision from CharmHub",
      "managerFilePatterns": [
        "/\\.tftest\\.hcl$/",
        "/\\.tf$/"
      ],
      "matchStrings": [
        "# renovate: depName=\"(?<packageName>[^\"]+)\"\\s*\\n\\s*(?<fieldName>[a-zA-Z0-9_]+)\\s*=\\s*(?<currentValue>\\d+)"
      ],
      "versioningTemplate": "semver-coerced"
    }
  ],
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "ignorePaths": [], // Override defaults from config:recommended
  "packageRules": [
    {
      "enabled": true,
      "matchDatasources": [
        "github-tags"
      ],
      "pinDigests": true
    },
    {
      "automerge": true,
      "enabled": true,
      "matchDatasources": [
        "custom.charmhub"
      ]
    },
    {
      "description": "Split minor and patch updates for MediaWiki",
      "matchSourceUrls": [
        "https://gerrit.wikimedia.org/r/mediawiki/core"
      ],
      "separateMinorPatch": true
    },
    {
      "description": "Only stable patch updates for MediaWiki",
      "matchSourceUrls": [
        "https://gerrit.wikimedia.org/r/mediawiki/core"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "enabled": false
    }
  ]
}
