{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "composer": {
    "managerFilePatterns": [
      "/^composer-?[a-z]*.json$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "description": "Update base image references",
      "managerFilePatterns": [
        "/(^|/)rockcraft.yaml$/"
      ],
      "matchStrings": [
        "# renovate: build-base:\\s+(?<depName>[^:]*):(?<currentValue>[^\\s@]*)(@(?<currentDigest>sha256:[0-9a-f]*))?",
        "# renovate: base:\\s+(?<depName>[^:]*):(?<currentValue>[^\\s@]*)(@(?<currentDigest>sha256:[0-9a-f]*))?"
      ],
      "matchStringsStrategy": "any",
      "versioningTemplate": "ubuntu"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "git-tags",
      "depNameTemplate": "https://gerrit.wikimedia.org/r/mediawiki/core.git",
      "description": "Update MediaWiki MW_VERSION from upstream tags",
      "managerFilePatterns": [
        "/(^|/)mediawiki_rock/rockcraft.yaml$/"
      ],
      "matchStrings": [
        "- MW_VERSION:\\s*(?<currentValue>[^\\s]+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "Lusitaniae/apache_exporter",
      "description": "Update Apache Exporter source",
      "fileMatch": [
        "(^|/)rockcraft.yaml$"
      ],
      "matchStrings": [
        "source:.*Lusitaniae/apache_exporter\\.git.*\\n.*source-tag: (?<currentValue>.+)"
      ],
      "matchStringsStrategy": "any",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ],
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "enabled": true,
      "matchDatasources": [
        "docker",
        "github-tags"
      ],
      "pinDigests": true
    },
    {
      "enabled": true,
      "matchDatasources": [
        "terraform-provider"
      ],
      "matchPackageNames": [
        "juju/juju"
      ]
    },
    {
      "description": "Split minor and patch updates for MediaWiki",
      "matchSourceUrls": [
        "https://gerrit.wikimedia.org/r/mediawiki/core"
      ],
      "separateMinorPatch": true
    },
    {
      "description": "Only stable patch updates for MediaWiki",
      "matchSourceUrls": [
        "https://gerrit.wikimedia.org/r/mediawiki/core"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "enabled": false
    }
  ]
}
